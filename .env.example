# Local development may leave both values empty. Production fails closed unless
# either the legacy username/password pair or the multi-account credential list
# is configured together with a high-entropy token.
APPLE_COOKBOOK_ADMIN_USERNAME=admin
APPLE_COOKBOOK_ADMIN_PASSWORD=

# Preferred production configuration: Base64-encoded JSON, for example
# [{"username":"Qin","password":"use-a-strong-password"}]. Keep the actual
# value in the deployment secret manager, never in this file or in Git.
APPLE_COOKBOOK_ADMIN_ACCOUNTS_BASE64=

# Generate a unique token with `openssl rand -base64 32` for each deployment.
# Store the generated value in the deployment secret manager; never commit it.
APPLE_COOKBOOK_ADMIN_TOKEN=

# Writable feedback deployments must point to a persistent directory outside
# the Git checkout, for example /var/lib/apple-cookbook on ECS. Vercel's local
# filesystem is intentionally rejected by the file-backed feedback store.
APPLE_COOKBOOK_DATA_DIR=

# Optional: dispatch the feedback intake workflow immediately after a durable
# website submission. Use a fine-grained token limited to Actions: write for
# this repository. Without it, the scheduled sync remains the fallback.
APPLE_COOKBOOK_GITHUB_TOKEN=
APPLE_COOKBOOK_GITHUB_REPOSITORY=Neverwhateve/apple-cookbook
APPLE_COOKBOOK_FEEDBACK_WORKFLOW=sync-feedback-intake.yml

# The same Actions-write token can dispatch administrator article edits. The
# workflow reads the durable proposal from APPLE_COOKBOOK_DATA_DIR, validates
# its full-file hashes, and publishes it through a harvest/* pull request.
APPLE_COOKBOOK_ADMIN_EDIT_WORKFLOW=publish-admin-article-edit.yml
