{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apple-cookbook.local/schemas/harvest-run.schema.json",
  "title": "Apple Cookbook Harvest Run Manifest",
  "description": "Harvest conflict guard v2. Whole-file content hashes remain intentionally strict; v2 also requires an auditable canonical-match decision for every change.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runId",
    "automationId",
    "generatedAt",
    "baseCommit",
    "changes"
  ],
  "properties": {
    "schemaVersion": {
      "const": 2
    },
    "runId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,99}$"
    },
    "automationId": {
      "type": "string",
      "minLength": 2,
      "maxLength": 100
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "baseCommit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40,64}$"
    },
    "changes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "$ref": "#/$defs/change"
      }
    }
  },
  "$defs": {
    "hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "change": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "action",
        "baseContentHash",
        "proposedContentHash",
        "reason",
        "canonicalReview"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^cookbook/(?:[^./][^/]*/)*[^./][^/]*\\.md$"
        },
        "action": {
          "enum": ["create", "update", "redirect"]
        },
        "baseContentHash": {
          "description": "SHA-256 of the complete Markdown blob at baseCommit, or null for create.",
          "oneOf": [
            { "$ref": "#/$defs/hash" },
            { "type": "null" }
          ]
        },
        "proposedContentHash": {
          "description": "SHA-256 of the complete proposed Markdown file.",
          "$ref": "#/$defs/hash"
        },
        "canonicalArticleId": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "canonicalReview": {
          "$ref": "#/$defs/canonicalReview"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "action": { "const": "create" } },
            "required": ["action"]
          },
          "then": {
            "properties": { "baseContentHash": { "type": "null" } }
          },
          "else": {
            "properties": { "baseContentHash": { "$ref": "#/$defs/hash" } }
          }
        },
        {
          "if": {
            "properties": { "action": { "const": "redirect" } },
            "required": ["action"]
          },
          "then": {
            "required": ["canonicalArticleId"]
          },
          "else": {
            "not": {
              "required": ["canonicalArticleId"]
            }
          }
        },
        {
          "if": {
            "properties": { "action": { "const": "create" } },
            "required": ["action"]
          },
          "then": {
            "properties": {
              "canonicalReview": {
                "properties": { "decision": { "const": "create-new" } }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "action": { "const": "update" } },
            "required": ["action"]
          },
          "then": {
            "properties": {
              "canonicalReview": {
                "properties": { "decision": { "const": "update-existing" } }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "action": { "const": "redirect" } },
            "required": ["action"]
          },
          "then": {
            "properties": {
              "canonicalReview": {
                "properties": { "decision": { "const": "redirect-to-existing" } }
              }
            }
          }
        }
      ]
    },
    "canonicalReview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["queries", "matchedArticleIds", "decision", "notes"],
      "properties": {
        "queries": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        },
        "matchedArticleIds": {
          "type": "array",
          "maxItems": 50,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        },
        "decision": {
          "enum": ["create-new", "update-existing", "redirect-to-existing"]
        },
        "notes": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        }
      }
    }
  }
}
