{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cookbook.wuxiela.fun/schemas/article-edit-proposal.schema.json",
  "title": "Apple Cookbook article edit proposal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "proposalId",
    "createdAt",
    "articlePath",
    "baseContentHash",
    "proposedContentHash",
    "proposedContent"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "proposalId": {
      "type": "string",
      "pattern": "^AE-[0-9]{8}-[A-Z0-9]{8}$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,3})?Z$"
    },
    "articlePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "pattern": "^cookbook/(?:[^/]+/)*[^/]+\\.md$"
    },
    "baseContentHash": {
      "$ref": "#/$defs/contentHash"
    },
    "proposedContentHash": {
      "$ref": "#/$defs/contentHash"
    },
    "proposedContent": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000000
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    }
  },
  "$defs": {
    "contentHash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
