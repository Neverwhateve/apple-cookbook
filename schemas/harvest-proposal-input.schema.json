{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apple-cookbook.local/schemas/harvest-proposal-input.schema.json",
  "title": "Apple Cookbook Harvest Proposal Input",
  "description": "Deterministic input for the local Harvest safety materializer. Complete Markdown is supplied by an upstream research process; this contract does not authorize publication or remote writes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runId",
    "automationId",
    "generatedAt",
    "baseCommit",
    "changes"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "runId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,99}$"
    },
    "automationId": {
      "type": "string",
      "minLength": 2,
      "maxLength": 100
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "baseCommit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40,64}$"
    },
    "changes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "$ref": "#/$defs/change"
      }
    }
  },
  "$defs": {
    "canonicalReview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["queries", "matchedArticleIds", "decision", "notes"],
      "properties": {
        "queries": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        },
        "matchedArticleIds": {
          "type": "array",
          "maxItems": 50,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        },
        "decision": {
          "enum": ["create-new", "update-existing", "redirect-to-existing"]
        },
        "notes": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        }
      }
    },
    "change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "action", "reason", "canonicalReview", "content"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^cookbook/(?:[^./][^/]*/)*[^./][^/]*\\.md$"
        },
        "action": {
          "enum": ["create", "update", "redirect"]
        },
        "reason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "canonicalArticleId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "canonicalReview": {
          "$ref": "#/$defs/canonicalReview"
        },
        "content": {
          "type": "string",
          "minLength": 1,
          "maxLength": 524288
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "action": { "const": "create" } },
            "required": ["action"]
          },
          "then": {
            "properties": {
              "canonicalReview": {
                "properties": { "decision": { "const": "create-new" } }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "action": { "const": "update" } },
            "required": ["action"]
          },
          "then": {
            "properties": {
              "canonicalReview": {
                "properties": { "decision": { "const": "update-existing" } }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "action": { "const": "redirect" } },
            "required": ["action"]
          },
          "then": {
            "required": ["canonicalArticleId"],
            "properties": {
              "canonicalReview": {
                "properties": { "decision": { "const": "redirect-to-existing" } }
              }
            }
          },
          "else": {
            "not": {
              "required": ["canonicalArticleId"]
            }
          }
        }
      ]
    }
  }
}
